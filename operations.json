{
    "title": "operations",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Auto-increment primary key"
        },
        "user_id": {
            "type": "string",
            "description": "User ID from auth"
        },
        "date": {
            "type": "string",
            "format": "date",
            "description": "Date of the operation"
        },
        "wins": {
            "type": "integer",
            "description": "Number of wins (1, 2, 3, 4...)"
        },
        "losses": {
            "type": "integer",
            "description": "Number of losses (1, 2, 3, 4...)"
        },
        "balance": {
            "type": "number",
            "description": "Bank balance value for the day in BRL"
        },
        "asset_type": {
            "type": "string",
            "description": "Type of asset: cripto, acao, commoditie"
        },
        "asset_name": {
            "type": "string",
            "description": "Specific name of the asset traded"
        }
    },
    "required": [
        "user_id",
        "date",
        "wins",
        "losses",
        "balance",
        "asset_type",
        "asset_name"
    ]
}
